class Account{
    protected:
        long accountNumber;
        string accountType;
        double balance;
        string status;
        Branch* branch;
        Customer* customer;

        struct Transaction {
            int transactionId;
            string transactionType;
            double amount;
            string status;
        };

        vector<Transaction> transactions;
        static int transactionCounter;

    public:
        Account(long accNum, const string& accType, double initialBalance, Branch* br, Customer* cust)
            : accountNumber(accNum), accountType(accType), balance(initialBalance),
              status("Active"), branch(br), customer(cust) {}

        virtual void deposit(double amount) {
            if (status == "Blocked") throw AccountBlockedException();
            if (amount <= 0) throw invalid_argument("Amount must be positive");
            balance += amount;
            Transaction t;
            t.transactionId = ++transactionCounter;
            t.transactionType = "Deposit";
            t.amount = amount;
            t.status = "Success";
            transactions.push_back(t);
            cout << "Deposited " << amount << " to account " << accountNumber << ". Balance: " << balance << endl;
        }

        virtual void withdraw(double amount) {
            if (status == "Blocked") throw AccountBlockedException();
            if (amount <= 0) throw invalid_argument("Amount must be positive");
            if (amount > balance) throw InsufficientBalanceException();
            balance -= amount;
            Transaction t;
            t.transactionId = ++transactionCounter;
            t.transactionType = "Withdrawal";
            t.amount = amount;
            t.status = "Success";
            transactions.push_back(t);
            cout << "Withdrew " << amount << " from account " << accountNumber << ". Balance: " << balance << endl;
        }

        void transfer(Account* receiver, double amount) {
            this->withdraw(amount);
            receiver->deposit(amount);
        }

        void printTransactionHistory() const {
            cout << "\n--- Transactions for Account " << accountNumber << " ---" << endl;
            for (const auto& t : transactions) {
                cout << "ID: " << t.transactionId
                     << " | Type: " << t.transactionType
                     << " | Amount: " << t.amount
                     << " | Status: " << t.status << endl;
            }
        }

        void setStatus(const string& s) { status = s; }
        string getStatus() const { return status; }
        long getAccountNumber() const { return accountNumber; }
        double getBalance() const { return balance; }

        virtual ~Account() {}
};

int Account::transactionCounter = 0;

class SavingsAccount: public Account {
    private:
        double interestRate;
        double minimumBalance;

    public:
        SavingsAccount(long accNum, double initialBalance, double intRate, double minBal, Branch* br, Customer* cust)
            : Account(accNum, "Savings", initialBalance, br, cust),
              interestRate(intRate), minimumBalance(minBal) {}

        void withdraw(double amount) override {
            if (status == "Blocked") throw AccountBlockedException();
            if (amount <= 0) throw invalid_argument("Amount must be positive");
            if ((balance - amount) < minimumBalance) throw InsufficientBalanceException();
            balance -= amount;
            Transaction t;
            t.transactionId = ++transactionCounter;
            t.transactionType = "Withdrawal";
            t.amount = amount;
            t.status = "Success";
            transactions.push_back(t);
            cout << "Withdrew " << amount << " from savings account " << accountNumber << ". Balance: " << balance << endl;
        }
};

class CurrentAccount: public Account {
    private:
        double overdraftLimit;
        string businessName;

    public:
        CurrentAccount(long accNum, double initialBalance, double odLimit, const string& bizName, Branch* br, Customer* cust)
            : Account(accNum, "Current", initialBalance, br, cust),
              overdraftLimit(odLimit), businessName(bizName) {}

        void withdraw(double amount) override {
            if (status == "Blocked") throw AccountBlockedException();
            if (amount <= 0) throw invalid_argument("Amount must be positive");
            if ((balance - amount) < -overdraftLimit) throw InsufficientBalanceException();
            balance -= amount;
            Transaction t;
            t.transactionId = ++transactionCounter;
            t.transactionType = "Withdrawal";
            t.amount = amount;
            t.status = "Success";
            transactions.push_back(t);
            cout << "Withdrew " << amount << " from current account " << accountNumber << ". Balance: " << balance << endl;
        }
};

