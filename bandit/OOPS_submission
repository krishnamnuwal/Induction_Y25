class Bank{
    public:
        int bankId;
        string bankName;
        vector<Branch*> branches;
        vector<Customer*> customers;
        vector<Employee*> employees;

        Bank(int id, const string& name) : bankId(id), bankName(name) {}

        ~Bank() {
            for (auto b : branches) delete b;
            for (auto c : customers) delete c;
            for (auto e : employees) delete e;
        }

        Branch* addBranch(int id, const string& name, const string& ifsc, const string& addr) {
            Branch* b = new Branch(id, name, ifsc, addr);
            branches.push_back(b);
            return b;
        }

        Customer* addCustomer(int id, const string& name, const string& gender,
                              const string& mobile, const string& email,
                              const string& addr, const string& aadhar, const string& pan) {
            Customer* c = new Customer(id, name, gender, mobile, email, addr, aadhar, pan);
            customers.push_back(c);
            return c;
        }

        SavingsAccount* openSavingsAccount(long accNum, double initialDeposit,
                                            double intRate, double minBal,
                                            Branch* branch, Customer* customer) {
            SavingsAccount* acc = new SavingsAccount(accNum, initialDeposit, intRate, minBal, branch, customer);
            customer->accounts.push_back(acc);
            return acc;
        }

        CurrentAccount* openCurrentAccount(long accNum, double initialDeposit,
                                            double odLimit, const string& bizName,
                                            Branch* branch, Customer* customer) {
            CurrentAccount* acc = new CurrentAccount(accNum, initialDeposit, odLimit, bizName, branch, customer);
            customer->accounts.push_back(acc);
            return acc;
        }
};

int main()
{
    Bank bank(1, "SmartBank");

    Branch* mainBranch = bank.addBranch(1, "Main Branch", "SMRT0001234", "123 MG Road, Bangalore");

    Customer* alice = bank.addCustomer(1, "Alice", "Female", "9876543210",
                                       "alice@email.com", "Bangalore", "1234-5678", "ABCPF1234D");

    Customer* bob = bank.addCustomer(2, "Bob", "Male", "9123456789",
                                     "bob@email.com", "Delhi", "9876-5432", "XYZPM9876G");

    SavingsAccount* aliceSavings = bank.openSavingsAccount(1001, 50000, 4.5, 1000, mainBranch, alice);
    CurrentAccount* bobCurrent = bank.openCurrentAccount(1002, 100000, 50000, "Bob Enterprises", mainBranch, bob);

    cout << "\n--- Transactions ---" << endl;
    try {
        aliceSavings->deposit(10000);
        aliceSavings->withdraw(5000);
        aliceSavings->transfer(bobCurrent, 2000);
    } catch (const InsufficientBalanceException& e) {
        cout << "[Error] " << e.what() << endl;
    } catch (const AccountBlockedException& e) {
        cout << "[Error] " << e.what() << endl;
    }

    cout << "\n--- Block Account Test ---" << endl;
    aliceSavings->setStatus("Blocked");
    try {
        aliceSavings->deposit(1000);
    } catch (const AccountBlockedException& e) {
        cout << "[Error] " << e.what() << endl;
    }
    aliceSavings->setStatus("Active");

    cout << "\n--- ATM Card Test ---" << endl;
    ATMCard* aliceCard = new ATMCard(4111111111111111L, 123, 1234, "Debit", aliceSavings);
    try {
        aliceCard->withdraw(1234, 1000);
        aliceCard->withdraw(9999, 1000);
    } catch (const InvalidPinException& e) {
        cout << "[Error] " << e.what() << endl;
    } catch (const InsufficientBalanceException& e) {
        cout << "[Error] " << e.what() << endl;
    }

    cout << "\n--- Loan Test ---" << endl;
    Loan* loan = new Loan(1, "Home", 5000000, 8.5, 20, alice);
    loan->approveLoan();

    cout << "\n--- Notifications ---" << endl;
    SMSNotification sms(alice->mobileNumber, "Your account was credited.");
    EmailNotification email(alice->email, "Statement", "Your April statement is ready.");
    alice->sendNotification(&sms);
    alice->sendNotification(&email);

    cout << "\n--- Transaction History ---" << endl;
    aliceSavings->printTransactionHistory();
    bobCurrent->printTransactionHistory();

    for (auto acc : alice->accounts) delete acc;
    for (auto acc : bob->accounts) delete acc;
    delete aliceCard;
    delete loan;

    return 0;
}
