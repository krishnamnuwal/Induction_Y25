class ATMCard{
    private:
        long cardNumber;
        int CVV;
        int PIN;
        string cardType;
        string cardStatus;
        Account* linkedAccount;

    public:
        ATMCard(long cardNum, int cvv, int pin, const string& type, Account* acc)
            : cardNumber(cardNum), CVV(cvv), PIN(pin),
              cardType(type), cardStatus("Active"), linkedAccount(acc) {}

        void validatePIN(int enteredPIN) {
            if (enteredPIN != PIN) throw InvalidPinException();
        }

        void blockCard() {
            cardStatus = "Blocked";
            cout << "Card " << cardNumber << " blocked." << endl;
        }

        void withdraw(int enteredPIN, double amount) {
            if (cardStatus == "Blocked") throw AccountBlockedException();
            validatePIN(enteredPIN);
            linkedAccount->withdraw(amount);
        }
};

